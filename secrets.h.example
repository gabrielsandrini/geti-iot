#pragma once
// Template for Blynk credentials.
//   1. Copy this file to `secrets.h`  (cp secrets.h.example secrets.h)
//   2. Fill in your real values from Blynk.Console (Device -> Device Info)
// `secrets.h` is gitignored, so your real token never reaches the repo.
#define BLYNK_TEMPLATE_ID   "TMPLxxxxxxxx"
#define BLYNK_TEMPLATE_NAME "Your Template Name"
#define BLYNK_AUTH_TOKEN    "YourAuthTokenHere"
